{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rosterbuilder.local/schemas/army-state.schema.json",
  "title": "ArmyState",
  "type": "object",
  "required": ["schemaVersion", "rulesetId", "armyId", "detachmentId", "warlordInstanceId", "attachments", "enhancements"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "rulesetId": { "type": "string", "minLength": 1 },
    "armyId": { "type": ["string", "null"] },
    "detachmentId": { "type": ["string", "null"] },
    "detachmentIds": { "type": "array", "items": { "type": "string" } },
    "warlordInstanceId": { "type": ["string", "null"] },
    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["leaderInstanceId", "targetInstanceId"],
        "properties": {
          "leaderInstanceId": { "type": "string" },
          "targetInstanceId": { "type": "string" }
        }
      }
    },
    "enhancements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["enhancementId", "bearerInstanceId"],
        "properties": {
          "enhancementId": { "type": "string" },
          "bearerInstanceId": { "type": "string" }
        }
      }
    }
  }
}
