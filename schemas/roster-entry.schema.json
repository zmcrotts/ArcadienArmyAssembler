{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rosterbuilder.local/schemas/roster-entry.schema.json",
  "title": "RosterEntry",
  "type": "object",
  "required": ["schemaVersion", "instanceId", "unitId", "selections"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "instanceId": { "type": "string", "minLength": 1 },
    "unitId": { "type": "string", "minLength": 1 },
    "selections": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "wargear": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    }
  }
}
