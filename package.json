{
  "name": "my-own-rosterbuilder",
  "version": "1.0.0",
  "description": "Offline Warhammer 40,000 roster builder.",
  "main": "electron/main.js",
  "scripts": {
    "test": "node --test test/*.test.js",
    "build:user": "node scripts/build-user-runtime.js",
    "desktop": "npm.cmd run build:user && electron .",
    "prepare:icons": "node scripts/write-crosshair-icon.js",
    "dist:dir": "npm.cmd run prepare:icons && npm.cmd run build:user && node scripts/build-electron-dir.js",
    "dist:local-installer": "npm.cmd run dist:dir && node scripts/build-local-installer.js",
    "dist:win": "npm.cmd run build:user && electron-builder --win nsis",
    "dist:linux": "npm.cmd run dist:linux:archive",
    "dist:linux:archive": "npm.cmd run prepare:icons && npm.cmd run build:user && electron-builder --linux tar.gz --config.directories.output=release/linux",
    "dist:linux:appimage": "npm.cmd run prepare:icons && npm.cmd run build:user && electron-builder --linux AppImage --config.directories.output=release/linux",
    "dist:linux:rpm": "npm.cmd run prepare:icons && npm.cmd run build:user && electron-builder --linux rpm --config.directories.output=release/linux",
    "dist:linux:flatpak": "npm.cmd run prepare:icons && npm.cmd run build:user && electron-builder --linux flatpak --config.directories.output=release/linux",
    "audit:bsdata-pricing": "node scripts/audit-bsdata-unit-pricing.js",
    "audit:bsdata-loadouts": "node scripts/audit-bsdata-loadouts.js",
    "audit:bsdata-armies": "node scripts/audit-bsdata-armies.js",
    "audit:ruleset-source": "node scripts/audit-ruleset-source.js",
    "health": "node scripts/project-health.js"
  },
  "keywords": [],
  "author": {
    "name": "zmcrotts",
    "email": "zmcrotts@users.noreply.github.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/zmcrotts/ArcadienArmyAssembler#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zmcrotts/ArcadienArmyAssembler.git"
  },
  "type": "commonjs",
  "dependencies": {
    "fast-xml-parser": "^5.9.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "local.rosterbuilder.app",
    "productName": "Arcadien Army Assembler",
    "directories": {
      "output": "release"
    },
    "files": [
    "electron/main.js",
    "electron/preload.js",
    "electron/manual-roster-sync.js",
      "dist-user/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "win": {
      "icon": "build/crosshair.ico",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/crosshair.png",
      "category": "Utility",
      "artifactName": "${productName} Linux ${version}.${ext}",
      "target": [
        "AppImage"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Arcadien Army Assembler"
    }
  }
}
